# FRED API key — get one at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here

# e-Stat (政府統計の総合窓口) API appId
# 取得手順: https://www.e-stat.go.jp/api/api-info/api-guide （無料登録、即時発行）
# CPIコアコア（生鮮食品及びエネルギー除く総合）前年同月比の取得に使用。
# 未設定時は総務省統計局CSVフォールバック → それも失敗ならモック値で動作する。
ESTAT_APP_ID=your_estat_app_id_here

# （任意）e-Stat の CPI 統計表ID。デフォルト: 0003427113 (2020年基準・月次・全国)
# ESTAT_CPI_STATS_DATA_ID=0003427113
